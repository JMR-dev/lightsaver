{
  "name": "lightsaver",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "check-types": "pnpm -r --filter \"!./apps/**\" exec tsc --noEmit --pretty && pnpm -r --filter \"./apps/**\" exec tsc --noEmit --pretty",
    "codegen": "graphql-codegen --config ./codegen.ts",
    "start": "pnpm check-types && pnpm codegen && turbo run build",
    "test:unit": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Jason Ross",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.17.0"
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "graphql": "^16.11.0",
    "lightsaver": "workspace:*"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-resolvers": "^4.5.1",
    "@parcel/watcher": "^2.5.1",
    "pnpm": "^10.13.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
