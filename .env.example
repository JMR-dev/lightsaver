# PostgreSQL
POSTGRES_USER=kratos
POSTGRES_PASSWORD=change_me_to_a_secure_password
POSTGRES_DB=kratos

# Kratos Secrets (generate with: openssl rand -base64 32)
KRATOS_SECRETS_COOKIE=change_me_32_char_secret_key_here_1234
KRATOS_SECRETS_CIPHER=change_me_32_char_cipher_key_here_123

# Kratos Mode
KRATOS_DEV_MODE=true

# URLs
KRATOS_PUBLIC_URL=http://localhost:4433
KRATOS_ADMIN_URL=http://localhost:4434
NEXT_PUBLIC_KRATOS_PUBLIC_URL=http://localhost:4433
NEXT_PUBLIC_APP_URL=http://localhost:3000
